{"id": "n-retries-backoff", "question": "What backoff strategy does the client use when retrying failed requests?", "type": "normal", "expected_answer": "Exponential backoff with full jitter, base 200ms doubling each attempt, capped at 8 seconds, up to 5 retries.", "keypoints": ["exponential backoff", "200ms", "8 seconds"], "relevant_doc_ids": ["retries"]}
