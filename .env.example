# Copy to .env and fill in. Everything is optional: with NO key the app runs in
# mock mode (offline, deterministic) and reports are tagged mock_mode=true.

# --- Cohere access ---------------------------------------------------------
# Your Cohere API key (either of these works):
CO_API_KEY=
# GRA_COHERE__API_KEY=

# Force the offline mock client even when a key is present:
# GRA_MOCK_MODE=true

# --- Models (defaults shown; verified current against docs.cohere.com) ------
# GRA_COHERE__EMBED_MODEL=embed-english-v3.0
# GRA_COHERE__RERANK_MODEL=rerank-v3.5
# GRA_COHERE__GENERATION_MODEL=command-a-03-2025

# --- Retrieval A/B toggles -------------------------------------------------
# GRA_RETRIEVAL__MODE=hybrid          # hybrid | dense
# GRA_RETRIEVAL__USE_RERANKER=true
# GRA_RETRIEVAL__EMBED_FILE_PATH=true

# --- Pricing (set to your account's rates to get real cost numbers) --------
# Until set these are 0.0 and reports flag cost as unconfigured.
# GRA_COHERE__PRICING__COMMAND_A_INPUT_USD_PER_1M=
# GRA_COHERE__PRICING__COMMAND_A_OUTPUT_USD_PER_1M=
# GRA_COHERE__PRICING__EMBED_ENGLISH_V3_USD_PER_1M=
# GRA_COHERE__PRICING__RERANK_V35_USD_PER_1K_SEARCHES=

# --- Logging ---------------------------------------------------------------
# GRA_LOG_LEVEL=INFO
# GRA_LOG_JSON=true
